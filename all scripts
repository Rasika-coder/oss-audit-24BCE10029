#!/bin/bash
# Script 4: Log File Analyzer
# Author: Rasika Jain

# -------- Arguments --------
LOGFILE=$1
KEYWORD=${2:-"error"}   # Default keyword = error
COUNT=0

# -------- Check file exists --------
if [ ! -f "$LOGFILE" ]; then
    echo "Error: File $LOGFILE not found."
    exit 1
fi

# -------- Retry if file is empty (do-while style) --------
while [ ! -s "$LOGFILE" ]; do
    echo "File is empty. Waiting for content..."
    sleep 2
done
