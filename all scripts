#!/bin/bash
# Script 2: FOSS Package Inspector
# Author: Rasika Jain

# -------- Variable --------
PACKAGE="firefox"   # You can change this (e.g., vlc, git, mysql)

# -------- Check if package is installed --------
if dpkg -l | grep -w $PACKAGE > /dev/null 2>&1
then
    echo "$PACKAGE is installed."

    # Show version and description
    dpkg -l | grep -w $PACKAGE

else
    echo "$PACKAGE is NOT installed."
fi

# -------- Case Statement --------
case $PACKAGE in
    firefox)
        echo "Firefox: a privacy-focused open source web browser"
        ;;
    vlc)
        echo "VLC: a powerful open source media player for all formats"
        ;;
    git)
        echo "Git: distributed version control system for developers"
        ;;
    mysql)
        echo "MySQL: open source database powering web applications"
        ;;
    *)
        echo "Unknown package: open source software for general use"
        ;;
Esac



Paragraph Explanation:
This script checks whether a specified open-source software package is installed on the system using the dpkg -l command combined with grep. If the package is found, it displays its details such as version and description; otherwise, it reports that the package is not installed. The script uses an if-then-else statement for decision-making and a case statement to print a short description of the software based on its name. It also demonstrates the use of pipes (|) with grep for filtering output. Overall, the script helps in inspecting installed packages and understanding their purpose.

Script 3 — Disk and Permission Auditor
.ch file:
#!/bin/bash
# Script 3: Disk and Permission Auditor
# Author: Rasika Jain

# -------- Directories to check --------
DIRS=("/etc" "/var/log" "/home" "/usr/bin" "/tmp")

echo "Directory Audit Report"
echo "----------------------"

# -------- Loop through directories --------
for DIR in "${DIRS[@]}"; do
    if [ -d "$DIR" ]; then
        # Get permissions, owner, group
        PERMS=$(ls -ld $DIR | awk '{print $1, $3, $4}')
        
        # Get size
        SIZE=$(du -sh $DIR 2>/dev/null | cut -f1)
        
        echo "$DIR => Permissions: $PERMS | Size: $SIZE"
    else
        echo "$DIR does not exist on this system"
    fi
done

echo ""
echo "Software Configuration Directory Check"
echo "--------------------------------------"

# -------- Check config directory (example: git) --------
CONFIG_DIR="$HOME/.gitconfig"

if [ -e "$CONFIG_DIR" ]; then
    PERMS=$(ls -ld $CONFIG_DIR | awk '{print $1, $3, $4}')
    echo "$CONFIG_DIR exists => Permissions: $PERMS"
else
    echo "$CONFIG_DIR does not exist"
Fi
